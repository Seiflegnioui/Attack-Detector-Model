# Virtual environments and git
venv/
.env/
__pycache__/
.git/
.gitignore

# Jupyter notebooks (not needed in production)
*.ipynb

# All .pkl files except the three the API needs
*.pkl
!models/best_model.pkl
!models/scaler.pkl
!models/model_columns.pkl

# Charts are served by Nginx directly from the host volume
*.png

# Training and data-prep scripts (not needed inside the API container)
src/

# Raw training data and extra test splits
data/KDDTrain+*
data/KDDTest-21*
data/processed/

# Frontend (served by the Nginx container)
frontend/
